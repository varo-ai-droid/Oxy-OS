{
  "manifest_version": 3,
  "name": "Oxy Chess Coach",
  "short_name": "OxyChess",
  "version": "1.0.0",
  "description": "Captures every chess.com move and logs it locally for AI-powered post-game analysis via Oxy OS.",
  "author": "Oxy OS",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_icon": "assets/icon-48.png",
    "default_title": "Oxy Chess Coach"
  },
  "content_scripts": [
    {
      "js": ["src/content/index.ts"],
      "matches": [
        "https://www.chess.com/*",
        "https://chess.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["https://*.chess.com/*"]
    }
  ],
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:9876/*"
  ],
  "homepage_url": ""
}